# .env.example — Foldy용
# 사용법: cp .env.example .env  →  실제 값 입력
# .env 는 gitignore 처리 — 절대 커밋 금지

DB_URL=jdbc:mysql://db:3306/foldy?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_NAME=foldy
DB_USERNAME=foldy_user
DB_PASSWORD=your_db_password_here
DB_ROOT_PASSWORD=your_root_password_here

JWT_SECRET=your_jwt_secret_min_32chars_here
JWT_EXPIRATION=86400000

GEMINI_API_KEY=

DDL_AUTO=update
LOG_LEVEL=INFO
THYMELEAF_CACHE=false
